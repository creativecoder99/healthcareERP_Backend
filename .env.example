# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── Database (Neon DB) ───────────────────────────────────────────────────────
# Get this from your Neon project: Settings → Connection string
# Use the "Pooled connection" URL for Prisma
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/medicore?sslmode=require"
# Direct connection for migrations (non-pooled)
DIRECT_URL="postgresql://user:password@ep-xxx-pooler.neon.tech/medicore?sslmode=require"

# ─── Redis (local Docker) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6382

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── S3 / MinIO (local Docker) ───────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DOCUMENTS=medicore-documents
S3_REGION=us-east-1
# In production, remove S3_ENDPOINT to use real AWS S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@medicore.in

# ─── AI Services ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
# AWS Textract (for OCR in Phase 3)
# AWS_TEXTRACT_REGION=ap-south-1

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
